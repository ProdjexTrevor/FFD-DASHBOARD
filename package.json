{
  "name": "first-dealer-direct-dashboard",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "db:test": "node scripts/test-db-connection.mjs",
    "db:migrate-creds": "node scripts/migrate-dashboard-creds.mjs",
    "db:create-user": "node scripts/create-dashboard-user.mjs",
    "dev:api": "node --watch server/index.js",
    "dev:client": "npm run dev --prefix client",
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:client\"",
    "build": "npm install --prefix client --include=dev && npm run build --prefix client"
  },
  "keywords": [],
