PORT=3080

# MariaDB (cache table: Dash_VinDecodes)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=firstdealer_app
DB_PASSWORD=
DB_NAME=firstdealer_app

# Optional single connection string instead of DB_* above
# DATABASE_URL=mysql://user:pass@127.0.0.1:3306/firstdealer_app

# Required in production. Send as: Authorization: Bearer <key>  OR  X-API-Key: <key>
API_KEY=change-me-to-a-long-random-secret

# Cache decoded VINs for this many days (default 90)
VIN_CACHE_DAYS=90

# If true, also read DealerTrack enrichment from vehicle_lookup_api_responses
# (only works when pointing at the First Dealer Direct MariaDB)
ENABLE_DEALERTRACK_ENRICHMENT=false

# Optional override (comma-separated). Leave blank to use the built-in major-make list.
# SUPPORTED_MAKES=FORD,HONDA,SUBARU,TOYOTA,CHEVROLET,GMC,RAM,NISSAN,HYUNDAI,KIA,BMW,MERCEDES-BENZ
