DB_HOST=host07.prodjex.com
DB_PORT=3306
DB_USER=firstdealer_app
DB_PASSWORD=
DB_NAME=firstdealer_app
DATABASE_URL=mysql://firstdealer_app:YOUR_PASSWORD@host07.prodjex.com:3306/firstdealer_app
PORT=3001

# When running the API on host07 itself, prefer localhost:
# DB_HOST=127.0.0.1

# Dashboard-Creds bootstrap (optional, used by npm run db:migrate-creds)
DASHBOARD_BOOTSTRAP_USER=admin
DASHBOARD_BOOTSTRAP_PASSWORD=
DASHBOARD_BOOTSTRAP_DISPLAY_NAME=Dashboard Admin

# Set to true to skip HTTP Basic Auth locally
DASHBOARD_AUTH_DISABLED=false

# Vercel: proxy /api to your Prodjex-hosted Express API (same-origin for the browser)
# Example: https://ffd-api.prodjex.com
API_PROXY_URL=

# Optional client-side API URL (only if not using API_PROXY_URL on Vercel)
VITE_API_URL=
